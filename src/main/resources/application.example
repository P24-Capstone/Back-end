spring:
  datasource:
    url: jdbc:[DB_URL]
    username: [DB_USERNAME]
    password: [DB_PASSWORD]
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: none
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  data:
    redis:
      host: [REDIS_HOST]
      port: [REDIS_PORT]

jwt:
  secret: [JWT_SECRET]
  expiration: 86400000

ai:
  serving:
    url: [AI_SERVING_URL]

storage:
  type: local   # S3 전환 시 's3' 로 변경
  local:
    upload-dir: [UPLOAD_DIR]
    base-url: [BASE_URL]