spring:
  datasource:
    url: jdbc:[DB_URL]
    username: [DB_USERNAME]
    password: [DB_PASSWORD]
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: none
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  data:
    redis:
      host: [REDIS_HOST]
      port: [REDIS_PORT]

jwt:
  secret: [JWT_SECRET]
  expiration: 86400000